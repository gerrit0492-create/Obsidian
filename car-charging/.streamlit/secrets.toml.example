# Copy this file to  .streamlit/secrets.toml  and fill in your values.
# secrets.toml is git-ignored, so your token stays on your machine.
# Streamlit reads it automatically; the app also falls back to env vars.
#
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# Then run the app on your HOME network (so it can reach the meter + charger):
#   streamlit run app.py

# --- HomeWizard P1 meter ---------------------------------------------------
# Your meter's IP (HomeWizard app -> Settings -> Meter). Pre-fills the panel.
P1_HOST = "192.168.1.31"

# --- Peblar charger (live Local REST API) ----------------------------------
# Charger hostname/IP (already defaults to this in the app; override if needed).
CHARGER_HOST = "pblr-0012237.local"
# Paste the token from the charger: Advanced settings -> Local REST API.
# Treat it like a password. Regenerate it if it has ever been shared.
CHARGER_TOKEN = "paste-your-charger-token-here"

# --- Optional --------------------------------------------------------------
# APP_PASSWORD = ""                      # gate the app behind a password
# CAR_MAP = '{"ANWB": "Citroën ëC3", "ANWB Gerrit": "Kia Sorento"}'  # card label/UID -> car
# P1_REMOTE_URL = ""                     # relay URL to read P1 from outside home
