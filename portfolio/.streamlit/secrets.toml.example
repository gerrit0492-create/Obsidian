# Copy to .streamlit/secrets.toml (git-ignored) and fill in.
# The public portfolio needs nothing here; these unlock/configure the private area.

# Unlocks the private area (Tracker + Vacatures) in app.py, and locks the
# standalone tracker.py. Choose a strong value if you deploy app.py publicly.
# PRIVATE_PASSWORD = "choose-a-strong-password"

# Live vacancy search (Vacatures). Free key: https://developer.adzuna.com
# Without it a keyless fallback is used (lighter NL coverage).
# ADZUNA_APP_ID = "your-app-id"
# ADZUNA_APP_KEY = "your-app-key"
# Extra NL source (optional). Free key: https://jooble.org/api/about
# JOOBLE_API_KEY = "your-jooble-key"
# Broad aggregator incl. Google for Jobs (optional). Free tier: rapidapi.com → JSearch
# JSEARCH_API_KEY = "your-rapidapi-key"

# Link shown from the private overview back to your public portfolio.
# PORTFOLIO_URL = "https://gerrit0492-create.github.io/Obsidian/"

# Persistent tracker storage (so your data survives reboots and syncs across
# laptop + phone). Without these the tracker uses the local Excel file.
#   1. Create a private gist at https://gist.github.com with a file
#      "applications.json" containing just: []
#   2. Copy its id from the URL (the long hash).
#   3. Create a token at https://github.com/settings/tokens with the "gist" scope.
# GIST_TOKEN = "ghp_your_token"
# GIST_ID = "your_gist_id"

# Optional AI: writes vacancy-aligned motivation letters + a real fit verdict.
# Set ANY ONE of these. The free options need NO credit card:
#   Gemini  — free key at https://aistudio.google.com/app/apikey  (recommended, free)
#   Groq    — free key at https://console.groq.com/keys           (free)
#   Anthropic — https://console.anthropic.com                     (paid, very cheap)
# Without any of them, a clean keyword-aligned template is used instead.
# GEMINI_API_KEY = "AIza..."
# GROQ_API_KEY = "gsk_..."
# ANTHROPIC_API_KEY = "sk-ant-..."
