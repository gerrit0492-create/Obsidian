# Copy to .streamlit/secrets.toml (git-ignored) and fill in.
# Only needed for the private tracker; the public portfolio needs nothing here.

# Locks the application tracker behind a password.
# TRACKER_PASSWORD = "choose-a-password"

# Live vacancy search (Vacatures tab). Free key: https://developer.adzuna.com
# Without it the tracker uses a keyless fallback with lighter NL coverage.
# ADZUNA_APP_ID = "your-app-id"
# ADZUNA_APP_KEY = "your-app-key"
