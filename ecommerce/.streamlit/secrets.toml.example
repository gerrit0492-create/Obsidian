# Kopieer dit naar .streamlit/secrets.toml (git-ignored) voor lokaal gebruik,
# of plak de regel in Streamlit Cloud → Manage app → Settings → Secrets.
#
# Schakelt de AI in de 🚀 Founder-check en 🔎 Niche-scan in. Gratis, geen creditcard:
#   Groq   — https://console.groq.com/keys          (aanbevolen, gratis)
#   Gemini — https://aistudio.google.com/app/apikey  (gratis)
#   Anthropic — https://console.anthropic.com         (betaald)
# Zonder key werkt de rest van het dashboard gewoon; de AI toont dan de prompts om te kopiëren.

# GROQ_API_KEY = "gsk_..."
# GEMINI_API_KEY = "AIza..."
# ANTHROPIC_API_KEY = "sk-ant-..."
